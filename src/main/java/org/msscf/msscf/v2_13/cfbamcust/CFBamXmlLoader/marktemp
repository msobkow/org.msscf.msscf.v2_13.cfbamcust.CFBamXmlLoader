for afile in DbKeyHash160 DbKeyHash224 DbKeyHash256 DbKeyHash384 DbKeyHash512 Uuid6
do
	cp -v CFBamXmlLoaderDbKeyHash128ColHandler.java CFBamXmlLoader${afile}ColHandler.java
	cp -v CFBamXmlLoaderDbKeyHash128GenHandler.java CFBamXmlLoader${afile}GenHandler.java
	cp -v CFBamXmlLoaderDbKeyHash128TypeHandler.java CFBamXmlLoader${afile}TypeHandler.java
	echo "1,\$s:DbKeyHash128:${afile}:g" >ex.cmd
	echo "wq" >>ex.cmd
	echo "" >>ex.cmd
	for anedit in CFBamXmlLoader${afile}*Handler.java
	do
		echo Updating $anedit ...
		ex $anedit <ex.cmd
	done
done
